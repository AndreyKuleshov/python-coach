# === Database ===
# Async SQLAlchemy URL (asyncpg driver). Matches deploy/docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://coach:<replace_me>@localhost:5544/coach

# === Sandbox (code-execution isolation) ===
# Image tag built from services/sandbox/Dockerfile (see `make sandbox-build`).
SANDBOX_IMAGE=python-coach-sandbox:latest
# Hard wall-clock kill for one submission run, in seconds.
SANDBOX_WALL_TIMEOUT_SECONDS=10
# Memory cap passed to `docker run --memory`.
SANDBOX_MEMORY_LIMIT=256m
# CPU cap passed to `docker run --cpus`.
SANDBOX_CPU_LIMIT=1.0
# Path to the docker CLI on the host running the API.
DOCKER_BIN=docker

# === Auth (JWT) ===
# HS256 signing secret for access + email-confirmation tokens. Required, no default.
JWT_SECRET=<replace_me>
# Access token lifetime in minutes.
JWT_ACCESS_TOKEN_MINUTES=1440
# Email-confirmation token lifetime in minutes.
JWT_CONFIRM_TOKEN_MINUTES=60

# === Email (SMTP, optional) ===
# Leave SMTP_HOST empty to log the confirmation link instead of sending it.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=<replace_me>
SMTP_FROM=no-reply@example.com
# Public base URL the confirmation link points at.
PUBLIC_BASE_URL=http://localhost:8077

# === OpenAI (AI hints + lesson chat, optional) ===
# Leave OPENAI_API_KEY empty to disable the AI features: hint/chat endpoints
# return 503 and the frontend hides the hint buttons + chat widget. The key
# lives ONLY here on the server; it is never sent to the browser.
OPENAI_API_KEY=
# Chat model used for hints + explanations.
OPENAI_MODEL=gpt-4o-mini
# Set true to run an offline canned-text mode (no network) — used by tests and
# the UI live-server so the suite never spends real tokens.
OPENAI_FAKE=false


DOMAIN_NAME=<replace_me>
COOLIFY_API_TOKEN=<replace_me>
COOLIFY_HOST=<replace_me>

