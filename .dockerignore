# Docker build context pruning. Build context = repo root.
# The harness, source books, build docs, dev tooling and tests must NEVER reach
# the deployed image. The production API image needs only:
#   pyproject.toml, uv.lock, services/api/pyproject.toml  (dependency install)
#   services/api/src/                                      (app + alembic migrations)
#   services/api/static/                                   (the SPA the API serves)
# Everything else below is excluded from the build context entirely.

# === Harness + build-time inputs (never ship) ===
.claude/
sources/
docs/
dev/
CURRICULUM.md
STORAGE_CONTRACT.md
README.md
CONTEXT.md

# === Fixtures: ship ONLY the real lesson_*.json (seeded on start), nothing else ===
# Exclude the whole dir, then re-include the real lessons. The throwaway
# placeholder stays excluded so the entrypoint seed glob never picks it up.
fixtures/*
!fixtures/lesson_*.json

# === VCS + meta ===
.git/
.gitignore
.dockerignore
.python-version

# === Local-dev deploy stack (Postgres compose; not part of the API image) ===
deploy/

# === Sandbox build context: now SHIPPED into the API image so the entrypoint
# can `docker build /app/sandbox` on the host at startup. (Previously excluded;
# kept in-context deliberately. Its sources are tiny and carry no secrets.) ===

# === Secrets / env (only the example may ever be present) ===
.env
.env.*
!.env.example

# === Python caches / virtualenv / tool caches ===
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.ruff_cache/
**/.grimp_cache/
**/.mypy_cache/
.import_linter_cache/
.venv/

# === Tests are not needed in the runtime image ===
services/api/tests/
