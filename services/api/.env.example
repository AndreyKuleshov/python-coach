# === Database ===
# Async SQLAlchemy URL (asyncpg driver). Matches deploy/docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://coach:<replace_me>@localhost:5544/coach

# === Sandbox (code-execution isolation) ===
# Image tag built from services/sandbox/Dockerfile (see `make sandbox-build`).
SANDBOX_IMAGE=python-coach-sandbox:latest
# Hard wall-clock kill for one submission run, in seconds.
SANDBOX_WALL_TIMEOUT_SECONDS=10
# Memory cap passed to `docker run --memory`.
SANDBOX_MEMORY_LIMIT=256m
# CPU cap passed to `docker run --cpus`.
SANDBOX_CPU_LIMIT=1.0
# Path to the docker CLI on the host running the API.
DOCKER_BIN=docker
